# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=resiliocart

# Application Configuration
# This is used by the web container to connect to the db container
DATABASE_URL=postgresql://user:password@db:5432/resiliocart?schema=public

# Security
# Generate a strong 32+ character secret for production
SESSION_SECRET=your_secret_session_key_here
